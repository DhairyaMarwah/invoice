# ---- Database: Turso / libSQL (required in production) ----
# Create a DB at https://turso.tech, then: turso db show <name> --url  /  turso db tokens create <name>
LIBSQL_URL=libsql://your-db.turso.io
LIBSQL_AUTH_TOKEN=your-turso-auth-token
# (TURSO_DATABASE_URL / TURSO_AUTH_TOKEN are also accepted as aliases.)
# Omit both to fall back to a local file at ./data/app.db (good for local dev).

# ---- File uploads: Vercel Blob (required on Vercel; contracts, logos, payment proofs) ----
# Vercel dashboard → Storage → Blob → create store; the token is injected automatically
# on Vercel. Set it locally only if you want uploads to go to Blob from your machine.
BLOB_READ_WRITE_TOKEN=
# Without this token, uploads are written to ./data/uploads and served via /api/files
# (fine locally / on a server with a persistent disk; NOT on Vercel's ephemeral FS).

# ---- AI (optional): contract OCR / field extraction via Vercel AI Gateway ----
# Omit and extraction falls back to text heuristics — nothing crashes.
AI_GATEWAY_API_KEY=

# ---- Self-hosted / Docker only ----
# Where the local-file DB + uploads live when not using Turso/Blob. Default: ./data
# DATA_DIR=/data
